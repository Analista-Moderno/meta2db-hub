generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MetaOAuthConfig {
  id             String   @id @default(cuid())
  userId         String   @unique
  accessToken    String
  expiresAt      DateTime?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model DestinationDatabase {
  id        String   @id @default(cuid())
  name      String
  host      String
  port      Int
  user      String
  password  String
  database  String
  jobs      PipelineJob[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PipelineJob {
  id            String   @id @default(cuid())
  name          String
  destinationId String
  destination   DestinationDatabase @relation(fields: [destinationId], references: [id])
  accounts      Json     
  level         String   
  datePreset    String   
  timeIncrement String   
  fields        Json     
  cronSchedule  String?  
  status        String   @default("active") 
  logs          JobLog[]
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model JobLog {
  id           String   @id @default(cuid())
  jobId        String
  job          PipelineJob @relation(fields: [jobId], references: [id])
  status       String   
  rowsInserted Int      @default(0)
  errorMessage String?
  payload      Json?    
  startedAt    DateTime @default(now())
  endedAt      DateTime?
}
